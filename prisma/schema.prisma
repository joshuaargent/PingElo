// PingElo - Prisma Schema
// Database schema for ping pong ELO tracking platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums
// ============================================

enum Role {
  PLAYER
  ADMIN
}

enum MatchType {
  SINGLES
  DOUBLES
}

enum TournamentFormat {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  SWISS
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// Models
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String
  image         String?
  passwordHash  String?
  role          Role      @default(PLAYER)
  isBanned      Boolean   @default(false)
  banReason     String?

  // Singles ELO tracking
  foreverElo     Int       @default(1000)
  seasonElo      Int       @default(1000)
  matchesPlayed  Int       @default(0)

  // Doubles ELO tracking
  doublesForeverElo     Int       @default(1000)
  doublesSeasonElo      Int       @default(1000)
  doublesMatchesPlayed  Int       @default(0)

  // Season tracking
  seasonId       String?
  season         Season?   @relation(fields: [seasonId], references: [id])

  // Timestamps
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relationships
  accounts       Account[]
  sessions       Session[]
  matchesAsP1    Match[]   @relation("Player1")
  matchesAsP2    Match[]   @relation("Player2")
  // Doubles relationships (all 4 positions)
  matchesAsT1P1 Match[]   @relation("Team1Player1")
  matchesAsT1P2 Match[]   @relation("Team1Player2")
  matchesAsT2P1 Match[]   @relation("Team2Player1")
  matchesAsT2P2 Match[]   @relation("Team2Player2")
  // Teams (as either player 1 or player 2)
  teamsAsP1      Team[]    @relation("TeamPlayer1")
  teamsAsP2      Team[]    @relation("TeamPlayer2")
  // Match creation
  createdMatches Match[]   @relation("MatchCreator")
  // Tournaments
  tournaments    TournamentParticipant[]
  createdTournaments Tournament[]
  seasonWins     Season[]  @relation("SeasonWinner")
  doublesSeasonWins Season[] @relation("SeasonDoublesWinner")
  // ELO History
  eloHistory     EloHistory[]
  // Weekly Activity
  weeklyActivity WeeklyActivity[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Season {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  winnerId    String?  @unique
  winnerElo   Int?
  doublesWinnerId String? @unique
  doublesWinnerElo Int?
  createdAt   DateTime @default(now())

  // Relationships
  winner        User?    @relation("SeasonWinner", fields: [winnerId], references: [id])
  doublesWinner User?    @relation("SeasonDoublesWinner", fields: [doublesWinnerId], references: [id])
  users         User[]
  matches       Match[]
  teamSeasonStats TeamSeasonStats[]
}

// Team model for doubles partnerships (persists across seasons)
model Team {
  id            String    @id @default(cuid())
  name          String?   // Optional custom name (e.g., "The Dynamic Duo")
  player1Id     String
  player2Id     String
  
  // Whether this team is currently active in the season
  isActive      Boolean   @default(true)
  
  // ELO tracking (average of both players' doubles ELO - persisted across seasons)
  foreverElo    Int       @default(1000)
  
  // Total stats across all seasons
  totalMatchesPlayed Int   @default(0)
  totalWins          Int   @default(0)
  totalLosses        Int   @default(0)

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  player1      User      @relation("TeamPlayer1", fields: [player1Id], references: [id])
  player2      User      @relation("TeamPlayer2", fields: [player2Id], references: [id])
  seasonStats  TeamSeasonStats[]
  tournamentParticipants TournamentParticipant[]

  // One team per partnership (regardless of season)
  @@unique([player1Id, player2Id])
  @@index([player1Id])
  @@index([player2Id])
  @@index([isActive])
}

// Per-season stats for a team
model TeamSeasonStats {
  id            String    @id @default(cuid())
  teamId        String
  team          Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  seasonId      String
  season        Season    @relation(fields: [seasonId], references: [id])
  
  // Season-specific ELO (resets each season)
  seasonElo     Int       @default(1000)
  
  // Season-specific stats
  matchesPlayed Int       @default(0)
  wins          Int       @default(0)
  losses        Int       @default(0)
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([teamId, seasonId])
  @@index([teamId])
  @@index([seasonId])
}

model Match {
  id            String    @id @default(cuid())
  matchType     MatchType @default(SINGLES)
  
  // For Singles matches
  player1Id     String?
  player2Id     String?
  
  // For Doubles matches - Team 1
  team1Player1Id String?
  team1Player2Id String?
  
  // For Doubles matches - Team 2  
  team2Player1Id String?
  team2Player2Id String?
  
  // Scores
  player1Score  Int       // Team 1 / Player 1 score
  player2Score  Int       // Team 2 / Player 2 score
  winnerId      String    // User ID of winner (for singles) or winning team's first player

  // ELO changes at time of match (applies to all relevant users/teams)
  player1EloBefore Int    // Player 1 or Team 1's ELO before
  player2EloBefore Int    // Player 2 or Team 2's ELO before
  player1EloChange Int    // Change for Player1/Team1 all members
  player2EloChange Int    // Change for Player2/Team2 all members

  // Season context
  seasonId      String?
  season        Season?   @relation(fields: [seasonId], references: [id])

  // Metadata
  isTournamentMatch Boolean @default(false)
  tournamentId      String?
  tournament        Tournament? @relation(fields: [tournamentId], references: [id])

  // Admin tracking
  createdById   String
  createdBy     User     @relation("MatchCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime? // Soft delete for admin

  // Relationships (Singles)
  player1       User?     @relation("Player1", fields: [player1Id], references: [id])
  player2       User?     @relation("Player2", fields: [player2Id], references: [id])
  
  // Relationships (Doubles)
  team1Player1  User?     @relation("Team1Player1", fields: [team1Player1Id], references: [id])
  team1Player2  User?     @relation("Team1Player2", fields: [team1Player2Id], references: [id])
  team2Player1  User?     @relation("Team2Player1", fields: [team2Player1Id], references: [id])
  team2Player2  User?     @relation("Team2Player2", fields: [team2Player2Id], references: [id])

  @@index([player1Id])
  @@index([player2Id])
  @@index([team1Player1Id])
  @@index([team1Player2Id])
  @@index([team2Player1Id])
  @@index([team2Player2Id])
  @@index([winnerId])
  @@index([seasonId])
  @@index([matchType])
}

model Tournament {
  id              String    @id @default(cuid())
  name            String
  description     String?
  creatorId       String

  // Tournament settings
  matchType       MatchType @default(SINGLES)
  entryFee        Int       @default(0)      // ELO cost to enter
  prizePool       Int       @default(0)      // House ELO added
  maxScore        Int       @default(21)     // Win condition (3-21)
  format          TournamentFormat @default(SINGLE_ELIMINATION)
  maxParticipants Int       @default(8)

  // Status
  status          TournamentStatus @default(DRAFT)
  startsAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  creator         User      @relation(fields: [creatorId], references: [id])
  participants    TournamentParticipant[]
  matches         Match[]
  brackets        TournamentBracket[]
}

model TournamentParticipant {
  id              String    @id @default(cuid())
  tournamentId    String
  userId          String?
  teamId          String?   // For doubles tournaments, the team participating
  eloAtEntry      Int       // Locked at entry time (user or team ELO)
  paidEntry       Boolean   @default(false)
  paidOut         Boolean   @default(false)
  finalPlacement  Int?
  createdAt       DateTime  @default(now())

  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user            User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team            Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@unique([tournamentId, teamId])
  @@index([tournamentId])
  @@index([userId])
  @@index([teamId])
}

// ============================================
// ELO History - Track individual ELO changes
// ============================================

enum EloChangeType {
  MATCH
  TOURNAMENT_WIN
  TOURNAMENT_PRIZE
  SEASON_BONUS
  ADMIN_ADJUSTMENT
  ADMIN_REVERT
}

model EloHistory {
  id            String         @id @default(cuid())
  userId        String
  matchId       String?        // Related match (if applicable)
  changeType    EloChangeType
  
  // ELO values
  eloBefore    Int            // ELO before this change
  eloAfter     Int            // ELO after this change
  change       Int            // Change amount (positive or negative)
  
  // Context
  description  String?        // Human-readable description
  metadata     Json?          // Additional context (opponent, tournament, etc.)
  
  // Timestamps
  createdAt    DateTime       @default(now())

  // Relationships
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([matchId])
  @@index([changeType])
  @@index([createdAt])
}

// ============================================
// Tournament Bracket - Track bracket structure
// ============================================

model TournamentBracket {
  id            String         @id @default(cuid())
  tournamentId  String

  // Bracket position
  round         Int            // Round number (1 = first round)
  position      Int            // Position within the round
  bracketType   String         @default("winner") // winner, loser, grand_final

  // Player tracking for this bracket slot
  player1Id     String?        // First player/team in this match
  player2Id     String?        // Second player/team in this match

  // Match tracking
  matchId       String?        // Related match in this bracket position
  winnerId      String?        // Winner of this match

  // Forbye tracking (automatic advancement)
  isBye         Boolean        @default(false)

  // Advancement tracking
  winnerAdvancesTo Int?        // Round number winner advances to
  loserAdvancesTo  Int?        // Round number loser advances to (for double elim)

  // Timestamps
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relationships
  tournament    Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, round, position, bracketType])
  @@index([tournamentId])
  @@index([round])
}

// ============================================
// Weekly Activity - Track weekly activity bonuses
// ============================================

model WeeklyActivity {
  id            String         @id @default(cuid())
  userId        String
  weekStart     DateTime      // Start of the week (Monday)
  
  // Activity tracking
  matchesPlayed Int            @default(0)
  wins          Int            @default(0)
  eloChange     Int            @default(0)     // Net ELO change this week
  activityBonus Int            @default(0)    // Bonus ELO earned
  
  // Status
  isQualified   Boolean        @default(false) // 2+ matches = qualified
  bonusAwarded  Boolean        @default(false)
  
  // Timestamps
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relationships
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
  @@index([weekStart])
  @@index([isQualified])
}
